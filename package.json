{
  "name": "be-template-ts",
  "version": "0.0.1",
  "description": "Backend Template TypeScript",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "prestart": "prisma generate",
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "db:push": "prisma generate && prisma db push",
    "db:fresh": "prisma generate && prisma db push --force-reset",
    "db:reset": "prisma generate && prisma db push --force-reset && tsx ./prisma/seeders/index.ts"
  },
  "author": "Galang Ekayudha",
  "license": "MIT",
  "imports": {
    "#app/*": "./app/*.js",
    "#prisma/*": "./prisma/*.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.7.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.19.11",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prisma": "^7.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
