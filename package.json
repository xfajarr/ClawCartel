{
  "name": "be-template-ts",
  "version": "0.0.1",
  "description": "Backend Template TypeScript",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "prestart": "prisma generate",
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "prisma generate && prisma db push",
    "db:fresh": "prisma generate && prisma db push --force-reset",
    "db:reset": "prisma generate && prisma db push --force-reset && tsx ./prisma/seeders/index.ts",
    "ws:monitor": "node ./scripts/ws-monitor.mjs",
    "ws:monitor:raw": "node ./scripts/ws-monitor-raw.mjs"
  },
  "author": "xfajarr",
  "license": "MIT",
  "imports": {
    "#app/*": "./app/*.js",
    "#prisma/*": "./prisma/*.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/wallet-standard-util": "^1.1.2",
    "@solana/web3.js": "^1.98.4",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "bs58": "^6.0.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.11",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prisma": "^7.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
